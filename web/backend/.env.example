# Weigh to Go! backend environment configuration.
# Copy this file to .env and adjust values for your environment.
# Never commit a populated .env file.
#
# Generate a secure SECRET_KEY with:
#   openssl rand -base64 32

# Application environment: development | test | production
ENVIRONMENT=development

# PostgreSQL connection string.
# Matches the docker-compose PostgreSQL service credentials below.
DATABASE_URL=postgresql+psycopg://weighttogo:weighttogo@localhost:5432/weighttogo_dev

# PostgreSQL container credentials, read by docker-compose.yml.
POSTGRES_USER=weighttogo
POSTGRES_PASSWORD=weighttogo
POSTGRES_DB=weighttogo_dev

# ── Authentication (SRS §12.5.1) ──────────────────────────────────────────────

# JWT signing key — REQUIRED, no default.
# Must be at least 32 random bytes (256 bits).  Generate with:
#   openssl rand -base64 32
SECRET_KEY=

# Access token lifetime in minutes (default: 15)
# ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days (default: 7)
# REFRESH_TOKEN_EXPIRE_DAYS=7

# Max consecutive login failures before account lockout (default: 5)
# MAX_LOGIN_ATTEMPTS=5

# Initial lockout duration in minutes (default: 15, subsequent cycles use
# exponential back-off capped at 24 hours)
# LOCKOUT_DURATION_MINUTES=15

# ── Security ──────────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins.  Wildcards NOT permitted.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Set to true ONLY when a trusted reverse proxy (nginx, AWS ALB) sits in front
# of the API and injects a reliable X-Forwarded-For header.  When true the
# rate limiter uses the rightmost XFF IP as the client key instead of
# REMOTE_ADDR.  Never enable if clients can set this header directly.
TRUSTED_PROXIES=false

# Minimum log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
