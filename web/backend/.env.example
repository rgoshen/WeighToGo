# Weigh to Go! backend environment configuration.
# Copy this file to .env and adjust values for your environment.
# Never commit a populated .env file.

# Application environment: development | test | production
ENVIRONMENT=development

# PostgreSQL connection string.
# Used by Alembic migrations now, and by the application runtime in later
# phases. Matches the docker-compose PostgreSQL service credentials below.
DATABASE_URL=postgresql+psycopg://weightogo:weightogo@localhost:5432/weightogo_dev

# PostgreSQL container credentials, read by docker-compose.yml.
POSTGRES_USER=weightogo
POSTGRES_PASSWORD=weightogo
POSTGRES_DB=weightogo_dev
